#!/usr/bin/env bash
#
# Convert Illustrator (.ai) files to PDF and PNG formats for publication.
#
# Requires .ai files to be PDF-compatible. Multi-artboard files are split
# into one 1-page PDF and one PNG per artboard.
#
# Usage: ai2pdfpng [OPTIONS]
#        ai2pdfpng [OPTIONS] FILE.ai
set -e

show_help() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS]
       $(basename "$0") [OPTIONS] FILE.ai

Convert Illustrator (.ai) files to PDF and PNG formats.
Requires .ai files to be PDF-compatible.
Multi-artboard files are split into one 1-page PDF and one PNG per artboard.

OPTIONS:
  -ai, --ai-folder DIR|FILE  AI files folder, or a single .ai file
                             (default: ./ai)
  -pdf, --pdf-folder DIR     Output PDF folder (default: ./pdf)
  -png, --png-folder DIR     Output PNG folder (default: ./png)
  -dpi, --dpi NUM            DPI for PDF images (default: 300)
  -h, --help                 Show this help message and exit
EOF
}

# Check for prerequisites
for tool in pdftoppm pdfseparate pdfinfo; do
    if ! command -v "$tool" &> /dev/null; then
        echo "$tool is required but it is not installed or not found in \$PATH."
        exit 1
    fi
done

# Parse command line arguments
# Set default values
ai_folder="./ai"
pdf_folder="./pdf"
png_folder="./png"
png_dpi=300

while [[ $# -gt 0 ]]; do
    case $1 in
        -ai|--ai-folder) ai_folder="$2"; shift 2 ;;
        -pdf|--pdf-folder) pdf_folder="$2"; shift 2 ;;
        -png|--png-folder) png_folder="$2"; shift 2 ;;
        -dpi|--dpi) png_dpi="$2"; shift 2 ;;
        -h|--help) show_help; exit 0 ;;
        -*) echo "Unknown option: $1"; exit 1 ;;
        *) ai_folder="$1"; shift ;;
    esac
done

# Make output directories - NO OVERWRITE to prevent data loss
for folder in "$pdf_folder" "$png_folder"; do
    if [ ! -d "$folder" ]; then
        mkdir "$folder"
    else
        echo "Directory '$folder' already exists. Exiting to prevent overwrite."
        exit 1
    fi
done

# Run conversion
if [ -f "$ai_folder" ]; then
    ai_files=("$ai_folder")
else
    ai_files=("$ai_folder"/*.ai)
fi

for ai_file in "${ai_files[@]}"; do
    # Check PDF compatibility via magic number
    if grep -q "%PDF-" "$ai_file"; then
        echo "Processing $ai_file ..."
        filename=$(basename "$ai_file")
        filestem="${filename%.ai}"
        npages=$(pdfinfo "$ai_file" | awk '/^Pages:/ {print $2}')

        if [ "$npages" -eq 1 ]; then
            # Single artboard: one PDF, one PNG, no page-number suffix.
            cp "$ai_file" "$pdf_folder/${filestem}.pdf"
            pdftoppm -singlefile -png -r "$png_dpi" \
                "$pdf_folder/${filestem}.pdf" \
                "$png_folder/${filestem}"
        else
            # Multiple artboards: split into one 1-page PDF per artboard,
            # then render each to its own PNG.
            pdfseparate "$ai_file" "$pdf_folder/${filestem}-%d.pdf"
            for page_pdf in "$pdf_folder/${filestem}"-*.pdf; do
                page_stem=$(basename "$page_pdf" .pdf)
                pdftoppm -singlefile -png -r "$png_dpi" \
                    "$page_pdf" \
                    "$png_folder/${page_stem}"
            done
        fi
    else
        echo "WARNING: $ai_file is not PDF-compatible. Skipping this file."
    fi
done

echo "All done."
