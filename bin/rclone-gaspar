#!/usr/bin/env zsh
#
# Drop-in replacement for rclone that prompts for an EPFL Gaspar password
# and exposes it to rclone through an environment variable, instead of
# requiring it to be stored in the rclone config (or any other file) in
# plain text.
#
# Usage: rclone-gaspar RCLONE_ARGS...
# Example: rclone-gaspar lsf nely-nas:files/
#
# An example ~/.config/rclone/rclone.conf file (notice that only the
# `user` is set, not `pass`):
#     [sv-nas]
#     type = smb
#     host = sv-nas1.rcp.epfl.ch
#     user = EPFL_USERNAME
#     domain = INTRANET.EPFL.CH
#     spn = sv-nas1.rcp.epfl.ch
#
#     [nely-nas]
#     type = alias
#     remote = sv-nas:upramdya
#
# To install rclone-gaspar:
#     1. Copy this file to ~/.local/bin/
#     2. Add execute permission: chmod ago+x ~/.local/bin/rclone-gaspar
#     3. If not done already, add ~/.local/bin/ to $PATH in your .zshrc

read -rs "pass?Gaspar password: "
echo
RCLONE_SMB_PASS=$(print -r -- "$pass" | rclone obscure -) rclone "$@"
