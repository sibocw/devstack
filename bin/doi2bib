#!/usr/bin/env bash
#
# Fetch, tidy, and print the BibTeX entry for a DOI or DOI URL, then copy
# it to the clipboard.
#
# Uses bibtex-tidy for formatting; see
# https://github.com/FlamingTempura/bibtex-tidy
# To install it (assuming npm is installed): npm install -g bibtex-tidy
#
# Usage: doi2bib DOI_OR_URL

show_help() {
    cat << EOF
Usage: doi2bib <DOI or URL>

Fetch, tidy, and print the BibTeX entry for a DOI (via the doi.org API),
then copy it to the clipboard.

EXAMPLES:
  doi2bib 10.1038/s41593-018-0210-5
  doi2bib https://doi.org/10.1101/2025.07.31.667571
EOF
}

# Help / input validation
if [[ "$1" == "-h" || "$1" == "--help" || -z "$1" ]]; then
    show_help
    exit 0
fi

# Extract DOI and setup temp .bib file
INPUT=$1
DOI=${INPUT#*doi.org/}
TEMP_BIB=$(mktemp /tmp/doi_XXXXXX.bib)

# Fetch the BibTeX via the doi.org API
# -f/--fail makes curl exit non-zero (instead of saving an HTML error page)
# on HTTP error responses, e.g. an unknown DOI.
if ! curl -sfLH "Accept: application/x-bibtex" "https://doi.org/$DOI" > "$TEMP_BIB" \
        || [ ! -s "$TEMP_BIB" ]; then
    echo "Error: Could not retrieve BibTeX for DOI $DOI"
    rm -f "$TEMP_BIB"
    exit 1
fi

# Format with bibtex-tidy (https://github.com/FlamingTempura/bibtex-tidy)
bibtex-tidy --modify --space=2 --quiet "$TEMP_BIB"

# Make key format consistent (e.g., Lastname2026)
# (doi.org API returns format like Lastname_2026)
# Note: the backup suffix must be attached to -i (no space) to work with
# both BSD sed (macOS) and GNU sed (Linux).
sed -i.bak -E 's/([A-Za-z])_([0-9]{4})/\1\2/g' "$TEMP_BIB"

# Change http://dx.doi.org/ to http://doi.org/
# (the dx. prefix is outdated)
sed -i.bak 's|http://dx.doi.org/|http://doi.org/|g' "$TEMP_BIB"
rm -f "$TEMP_BIB.bak"

# Output to terminal
cat "$TEMP_BIB"

# Copy to Clipboard
if [[ "$OSTYPE" == "darwin"* ]]; then
    cat "$TEMP_BIB" | pbcopy
    echo "--- Copied to macOS clipboard ---"
elif command -v xclip >/dev/null; then
    cat "$TEMP_BIB" | xclip -selection clipboard
    echo "--- Copied to Linux clipboard (xclip) ---"
elif command -v wl-copy >/dev/null; then
    cat "$TEMP_BIB" | wl-copy
    echo "--- Copied to Wayland clipboard ---"
fi

# Cleanup
rm "$TEMP_BIB"
